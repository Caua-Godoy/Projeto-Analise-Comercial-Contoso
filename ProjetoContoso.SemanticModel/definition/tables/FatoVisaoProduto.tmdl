				    #"Consultas Mescladas2" = Table.NestedJoin(#"DimCategoria Expandido", {"Subcategoria"}, DimSubcategoria, {"Subcategoria"}, "DimSubcategoria", JoinKind.Inner),
				    #"DimSubcategoria Expandido" = Table.ExpandTableColumn(#"Consultas Mescladas2", "DimSubcategoria", {"ID_subcategoria"}, {"ID_subcategoria"}),
				    #"Consultas Mescladas3" = Table.NestedJoin(#"DimSubcategoria Expandido", {"Marca"}, DimMarca, {"Marca"}, "DimMarca", JoinKind.Inner),
				    #"Colunas Removidas" = Table.RemoveColumns(#"Consultas Mescladas3",{"Produto", "Categoria", "Subcategoria", "Marca"}),
